<VirtualHost *:80>
  ServerName   <%= @server_name %>
  DocumentRoot <%= @docroot %>

  <Directory <%= @docroot %>>
    Options FollowSymLinks
    AllowOverride All

    Require all granted
  </Directory>

  Alias "/tests/PHPUnit/proxy/plugins" "<%= @docroot %>/plugins"

#  ProxyPassMatch "^/.*\.php(/.*)?$" "fcgi://localhost:9000/<%= @docroot.gsub(/^\/+|\/+$/, '') %>/"
</VirtualHost>
